<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DevMentalMd.App.Controls"
        xmlns:settings="clr-namespace:DevMentalMd.App.Settings"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="DevMentalMd.App.MainWindow"
        Title=""
        Width="900" Height="650"
        MinWidth="280" MinHeight="130"
		Icon="avares://dmedit/app_icon.ico"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="38">
	<Border x:Name="WindowBorder" ClipToBounds="True">
	<DockPanel>
		<!-- Tab bar (custom-drawn, sits in title bar area) -->
		<controls:TabBarControl x:Name="TabBar"
                                DockPanel.Dock="Top"
                                Height="38"
                                IsHitTestVisible="True" />

		<Border DockPanel.Dock="Top" x:Name="MenuBarBorder" BorderThickness="0,0,0,1">
			<Grid ColumnDefinitions="*,Auto">
				<Menu x:Name="MenuBar" Grid.Column="0" FontSize="12">
					<MenuItem Header="_File" x:Name="MenuFile">
						<MenuItem Header="_New" x:Name="MenuNew" />
						<MenuItem Header="_Open…" x:Name="MenuOpen" />
						<Separator />
						<MenuItem Header="_Save" x:Name="MenuSave" />
						<MenuItem Header="Save _As…" x:Name="MenuSaveAs" />
						<MenuItem Header="Save A_ll" x:Name="MenuSaveAll" />
						<Separator />
						<MenuItem Header="_Revert File" x:Name="MenuRevertFile" />
						<Separator />
						<MenuItem Header="_Close" x:Name="MenuClose" />
						<MenuItem Header="Close A_ll" x:Name="MenuCloseAll" />
						<Separator />
						<MenuItem Header="E_xit" x:Name="MenuExit" />
					</MenuItem>
					<MenuItem Header="_Edit" x:Name="MenuEdit">
						<MenuItem Header="_Undo" x:Name="MenuUndo" />
						<MenuItem Header="_Redo" x:Name="MenuRedo" />
						<Separator />
						<MenuItem Header="Cu_t" x:Name="MenuCut" />
						<MenuItem Header="_Copy" x:Name="MenuCopy" />
						<MenuItem Header="_Paste" x:Name="MenuPaste" />
						<MenuItem Header="Paste _More" x:Name="MenuPasteMore" />
						<MenuItem Header="De_lete" x:Name="MenuDelete" />
						<Separator />
						<MenuItem Header="Select _All" x:Name="MenuSelectAll" />
						<MenuItem Header="Select _Word" x:Name="MenuSelectWord" />
						<Separator />
						<MenuItem Header="Delete Li_ne" x:Name="MenuDeleteLine" />
						<MenuItem Header="Move Line _Up" x:Name="MenuMoveLineUp" />
						<MenuItem Header="Move Line Dow_n" x:Name="MenuMoveLineDown" />
						<Separator />
						<MenuItem Header="Insert Line _Below" x:Name="MenuInsertLineBelow" />
						<MenuItem Header="Insert Line A_bove" x:Name="MenuInsertLineAbove" />
						<MenuItem Header="D_uplicate Line" x:Name="MenuDuplicateLine" />
						<Separator />
						<MenuItem Header="Delete Word Le_ft" x:Name="MenuDeleteWordLeft" />
						<MenuItem Header="Delete Word Ri_ght" x:Name="MenuDeleteWordRight" />
						<MenuItem Header="In_dent" x:Name="MenuIndent" />
						<Separator />
						<MenuItem Header="Transform Case" x:Name="MenuTransformCase">
							<MenuItem Header="_Upper Case" x:Name="MenuCaseUpper" />
							<MenuItem Header="_Lower Case" x:Name="MenuCaseLower" />
							<MenuItem Header="_Proper Case" x:Name="MenuCaseProper" />
						</MenuItem>
						<Separator />
						<MenuItem Header="Advanced">
							<MenuItem Header="Select All _Occurrences" x:Name="MenuSelectAllOccurrences" />
							<MenuItem Header="Co_lumn Select" x:Name="MenuColumnSelect" />
						</MenuItem>
					</MenuItem>
					<MenuItem Header="_Search" x:Name="MenuSearch">
						<MenuItem Header="_Find" x:Name="MenuFind" />
						<MenuItem Header="_Replace" x:Name="MenuReplace" />
						<Separator />
						<MenuItem Header="Find _Next" x:Name="MenuFindNext" />
						<MenuItem Header="Find _Previous" x:Name="MenuFindPrevious" />
						<Separator />
						<MenuItem Header="Find _Word or Selection" x:Name="MenuFindWordOrSel" />
						<MenuItem Header="_Incremental Search" x:Name="MenuIncrementalSearch" />
						<Separator />
						<MenuItem Header="_Go to Line" x:Name="MenuGoToLine" />
						<Separator />
						<MenuItem Header="Command _Palette" x:Name="MenuCommandPalette" />
					</MenuItem>
					<MenuItem Header="_View" x:Name="MenuView">
						<MenuItem Header="_Line Numbers" x:Name="MenuLineNumbers" />
						<MenuItem Header="_Status Bar" x:Name="MenuStatusBar" />
						<Separator />
						<MenuItem Header="_Wrap Lines" x:Name="MenuWrapLines" />
						<Separator />
						<MenuItem Header="_Zoom">
							<MenuItem Header="Zoom _In" x:Name="MenuZoomIn" />
							<MenuItem Header="Zoom _Out" x:Name="MenuZoomOut" />
							<MenuItem Header="Zoom _Reset" x:Name="MenuZoomReset" />
						</MenuItem>
						<Separator />
						<MenuItem Header="Scroll Line _Up" x:Name="MenuScrollLineUp" />
						<MenuItem Header="Scroll Line _Down" x:Name="MenuScrollLineDown" />
					</MenuItem>
				</Menu>
				<Border x:Name="GearButton" Grid.Column="1"
						Background="Transparent"
						CornerRadius="4"
						Width="26" Height="26"
						VerticalAlignment="Center"
						Margin="2,0,6,0"
						ToolTip.Tip="Settings">
					<TextBlock x:Name="GearGlyph"
							   FontSize="20"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Center" />
				</Border>
			</Grid>
		</Border>

		<Border x:Name="StatusBar"
                DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0">
			<StackPanel>
				<!-- Dev stats bar (DevMode only) -->
				<TextBlock x:Name="StatsBar"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="11"
                           Padding="6,2,6,0"
                           Text="Stats: —" />
				<TextBlock x:Name="StatsBarIO"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="11"
                           Padding="6,0,6,2"
                           Text="Load: —  |  Save: —" />
				<!-- Permanent status bar (always visible).
				     Uses a single star column with Left/Right alignment so that text
				     changes never resize the grid — preventing layout invalidation
				     from cascading up through the DockPanel to the EditorControl. -->
				<Grid x:Name="PermanentStatusBar">
					<TextBlock x:Name="StatusLeft"
                               HorizontalAlignment="Left"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="11"
                               Padding="6,6,6,6"
                               Text="" />
					<TextBlock x:Name="StatusRight"
                               HorizontalAlignment="Right"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="11"
                               Padding="6,6,6,6"
                               Text="" />
				</Grid>
			</StackPanel>
		</Border>

		<!-- Settings and editor share the same fill area; only one is visible. -->
		<Grid>
			<settings:SettingsControl x:Name="SettingsPanel"
			                          IsVisible="False" />
			<Grid ColumnDefinitions="*,Auto" x:Name="EditorGrid">
				<controls:EditorControl x:Name="Editor"
				                        Grid.Column="0"
				                        HorizontalAlignment="Stretch" />
				<controls:FindBarControl x:Name="FindBar"
				                         Grid.Column="0"
				                         HorizontalAlignment="Right"
				                         VerticalAlignment="Top"
				                         Margin="0,-1,0,0"
				                         IsVisible="False" />
				<controls:DualZoneScrollBar x:Name="ScrollBar"
				                            Grid.Column="1"
				                            Focusable="False" />
			</Grid>
		</Grid>
	</DockPanel>
	</Border>
</Window>
