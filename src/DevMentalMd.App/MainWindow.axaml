<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DevMentalMd.App.Controls"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="DevMentalMd.App.MainWindow"
        Title="DevMentalMD"
        Width="900" Height="650">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File" x:Name="MenuFile">
                <MenuItem Header="_New" x:Name="MenuNew" />
                <MenuItem Header="_Open…" x:Name="MenuOpen" />
                <Separator />
                <MenuItem Header="_Save" x:Name="MenuSave" />
                <MenuItem Header="Save _As…" x:Name="MenuSaveAs" />
                <Separator />
                <MenuItem Header="_Close" x:Name="MenuClose" InputGesture="Ctrl+F4" />
                <MenuItem Header="Close A_ll" x:Name="MenuCloseAll" InputGesture="Ctrl+Shift+F4" />
            </MenuItem>
            <MenuItem Header="_Dev" x:Name="MenuDev">
                <MenuItem>
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Outer scroll rate:" VerticalAlignment="Center" />
                            <Slider x:Name="SliderOuterScrollRate"
                                    Width="140" Minimum="0.5" Maximum="10"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" />
                            <TextBlock x:Name="LabelOuterScrollRate"
                                       Width="30" VerticalAlignment="Center" />
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Border x:Name="StatusBar"
                DockPanel.Dock="Bottom"
                BorderBrush="#D0D0D0"
                BorderThickness="0,1,0,0"
                Background="#F0F0F0">
            <StackPanel>
                <TextBlock x:Name="StatsBar"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="11"
                           Foreground="#606060"
                           Padding="6,2,6,0"
                           Text="Stats: —" />
                <TextBlock x:Name="StatsBarIO"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="11"
                           Foreground="#606060"
                           Padding="6,0,6,2"
                           Text="Load: —  |  Save: —" />
            </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,Auto">
            <controls:EditorControl x:Name="Editor"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch" />
            <controls:DualZoneScrollBar x:Name="ScrollBar"
                                        Grid.Column="1" />
        </Grid>
    </DockPanel>
</Window>
