<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DevMentalMd.App.Controls"
        xmlns:settings="clr-namespace:DevMentalMd.App.Settings"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="DevMentalMd.App.MainWindow"
        Title=""
        Width="900" Height="650"
        MinWidth="280" MinHeight="130"
		Icon="avares://dmedit/app_icon.ico"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="38">
	<DockPanel>
		<!-- Tab bar (custom-drawn, sits in title bar area) -->
		<controls:TabBarControl x:Name="TabBar"
                                DockPanel.Dock="Top"
                                Height="38"
                                IsHitTestVisible="True" />

		<Border DockPanel.Dock="Top" x:Name="MenuBarBorder" BorderThickness="0,0,0,1">
			<Grid ColumnDefinitions="*,Auto">
				<Menu x:Name="MenuBar" Grid.Column="0" FontSize="12">
					<MenuItem Header="_File" x:Name="MenuFile">
						<MenuItem Header="_New" x:Name="MenuNew" InputGesture="Ctrl+N" />
						<MenuItem Header="_Open…" x:Name="MenuOpen" InputGesture="Ctrl+O" />
						<Separator />
						<MenuItem Header="_Save" x:Name="MenuSave" InputGesture="Ctrl+S" />
						<MenuItem Header="Save _As…" x:Name="MenuSaveAs" InputGesture="Ctrl+Alt+S"/>
						<MenuItem Header="Save A_ll" x:Name="MenuSaveAll" InputGesture="Ctrl+Shift+S"/>
						<Separator />
						<MenuItem Header="_Close" x:Name="MenuClose" InputGesture="Ctrl+F4" />
						<MenuItem Header="Close A_ll" x:Name="MenuCloseAll" InputGesture="Ctrl+Shift+F4" />
					</MenuItem>
					<MenuItem Header="_Edit" x:Name="MenuEdit">
						<MenuItem Header="_Undo" x:Name="MenuUndo" InputGesture="Ctrl+Z" />
						<MenuItem Header="_Redo" x:Name="MenuRedo" InputGesture="Ctrl+Shift+Z" />
						<Separator />
						<MenuItem Header="Cu_t" x:Name="MenuCut" InputGesture="Ctrl+X" />
						<MenuItem Header="_Copy" x:Name="MenuCopy" InputGesture="Ctrl+C" />
						<MenuItem Header="_Paste" x:Name="MenuPaste" InputGesture="Ctrl+V" />
						<MenuItem Header="Paste _More" x:Name="MenuPasteMore" InputGesture="Ctrl+Shift+V" />
						<MenuItem Header="De_lete" x:Name="MenuDelete" InputGesture="Delete" />
						<Separator />
						<MenuItem Header="Select _All" x:Name="MenuSelectAll" InputGesture="Ctrl+A" />
						<MenuItem Header="Select _Word" x:Name="MenuSelectWord" InputGesture="Ctrl+W" />
						<Separator />
						<MenuItem Header="Delete Li_ne" x:Name="MenuDeleteLine" InputGesture="Ctrl+Y" />
						<MenuItem Header="Move Line _Up" x:Name="MenuMoveLineUp" InputGesture="Alt+Up" />
						<MenuItem Header="Move Line Dow_n" x:Name="MenuMoveLineDown" InputGesture="Alt+Down" />
						<Separator />
						<MenuItem Header="Transform Case" x:Name="MenuTransformCase">
							<MenuItem Header="_Upper Case" x:Name="MenuCaseUpper" InputGesture="Ctrl+Shift+U" />
							<MenuItem Header="_Lower Case" x:Name="MenuCaseLower" InputGesture="Ctrl+Shift+L" />
							<MenuItem Header="_Proper Case" x:Name="MenuCaseProper" InputGesture="Ctrl+Shift+P" />
						</MenuItem>
					</MenuItem>
					<MenuItem Header="_View" x:Name="MenuView">
						<MenuItem Header="_Line Numbers" x:Name="MenuLineNumbers" />
						<MenuItem Header="_Status Bar" x:Name="MenuStatusBar" />
						<Separator />
						<MenuItem Header="_Wrap Lines" x:Name="MenuWrapLines" />
					</MenuItem>
				</Menu>
				<Border x:Name="GearButton" Grid.Column="1"
						Background="Transparent"
						CornerRadius="4"
						Width="24" Height="24"
						VerticalAlignment="Center"
						Margin="2,0,6,0"
						ToolTip.Tip="Settings">
					<TextBlock x:Name="GearGlyph"
							   FontSize="14"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Center" />
				</Border>
			</Grid>
		</Border>

		<Border x:Name="StatusBar"
                DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0">
			<StackPanel>
				<!-- Dev stats bar (DevMode only) -->
				<TextBlock x:Name="StatsBar"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="11"
                           Padding="6,2,6,0"
                           Text="Stats: —" />
				<TextBlock x:Name="StatsBarIO"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="11"
                           Padding="6,0,6,2"
                           Text="Load: —  |  Save: —" />
				<!-- Permanent status bar (always visible).
				     Uses a single star column with Left/Right alignment so that text
				     changes never resize the grid — preventing layout invalidation
				     from cascading up through the DockPanel to the EditorControl. -->
				<Grid x:Name="PermanentStatusBar">
					<TextBlock x:Name="StatusLeft"
                               HorizontalAlignment="Left"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="11"
                               Padding="6,6,6,6"
                               Text="" />
					<TextBlock x:Name="StatusRight"
                               HorizontalAlignment="Right"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="11"
                               Padding="6,6,6,6"
                               Text="" />
				</Grid>
			</StackPanel>
		</Border>

		<!-- Settings panel (replaces menu, editor, status bars when active) -->
		<settings:SettingsControl x:Name="SettingsPanel"
		                          IsVisible="False" />

		<Grid ColumnDefinitions="*,Auto" x:Name="EditorGrid">
			<controls:EditorControl x:Name="Editor"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch" />
			<controls:DualZoneScrollBar x:Name="ScrollBar"
                                        Grid.Column="1"
                                        Focusable="False" />
		</Grid>
	</DockPanel>
</Window>
