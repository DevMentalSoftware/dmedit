<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DevMentalMd.App.Controls"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="DevMentalMd.App.MainWindow"
        Title=""
        Width="900" Height="650"
		Icon="avares://dmedit/app_icon.ico"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="38">
    <DockPanel>
        <!-- Tab bar (custom-drawn, sits in title bar area) -->
        <controls:TabBarControl x:Name="TabBar"
                                DockPanel.Dock="Top"
                                Height="38"
                                IsHitTestVisible="True" />

        <Border DockPanel.Dock="Top" x:Name="MenuBarBorder" BorderThickness="0,0,0,1">
        <Menu x:Name="MenuBar" FontSize="12">
            <MenuItem Header="_File" x:Name="MenuFile">
                <MenuItem Header="_New" x:Name="MenuNew" />
                <MenuItem Header="_Open…" x:Name="MenuOpen" />
                <Separator />
                <MenuItem Header="_Save" x:Name="MenuSave" />
                <MenuItem Header="Save _As…" x:Name="MenuSaveAs" />
                <Separator />
                <MenuItem Header="_Close" x:Name="MenuClose" InputGesture="Ctrl+F4" />
                <MenuItem Header="Close A_ll" x:Name="MenuCloseAll" InputGesture="Ctrl+Shift+F4" />
            </MenuItem>
            <MenuItem Header="_View" x:Name="MenuView">
                <MenuItem Header="_Line Numbers" x:Name="MenuLineNumbers" />
                <MenuItem Header="_Status Bar" x:Name="MenuStatusBar" />
                <MenuItem Header="S_tatistics" x:Name="MenuStatistics" />
                <Separator />
                <MenuItem Header="_Wrap Lines" x:Name="MenuWrapLines" />
                <Separator />
                <MenuItem Header="_Theme" x:Name="MenuTheme">
                    <MenuItem Header="S_ystem" x:Name="MenuThemeSystem" />
                    <MenuItem Header="_Light" x:Name="MenuThemeLight" />
                    <MenuItem Header="_Dark" x:Name="MenuThemeDark" />
                </MenuItem>
            </MenuItem>
        </Menu>
        </Border>

        <Border x:Name="StatusBar"
                DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0">
            <StackPanel>
				<!-- Dev stats bar (DevMode only) -->
				<TextBlock x:Name="StatsBar"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="11"
                           Padding="6,2,6,0"
                           Text="Stats: —" />
				<TextBlock x:Name="StatsBarIO"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="11"
                           Padding="6,0,6,2"
                           Text="Load: —  |  Save: —" />
				<!-- Permanent status bar (always visible).
				     Uses a single star column with Left/Right alignment so that text
				     changes never resize the grid — preventing layout invalidation
				     from cascading up through the DockPanel to the EditorControl. -->
                <Grid x:Name="PermanentStatusBar">
                    <TextBlock x:Name="StatusLeft"
                               HorizontalAlignment="Left"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="11"
                               Padding="6,6,6,6"
                               Text="" />
                    <TextBlock x:Name="StatusRight"
                               HorizontalAlignment="Right"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="11"
                               Padding="6,6,6,6"
                               Text="" />
                </Grid>
            </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,Auto">
            <controls:EditorControl x:Name="Editor"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch" />
            <controls:DualZoneScrollBar x:Name="ScrollBar"
                                        Grid.Column="1"
                                        Focusable="False" />
        </Grid>
    </DockPanel>
</Window>
