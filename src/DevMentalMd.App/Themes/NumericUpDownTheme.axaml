<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- ══════════════════════════════════════════════════════════════════
	     Custom NumericUpDown theme — TextBox-like hover behaviour.
	     Each zone handles its own :pointerover independently:
	       • Text zone  → inner TextBox tints via TextControlBackgroundPointerOver
	       • Up button   → RepeatButton tints
	       • Down button  → RepeatButton tints
	     No cross-zone hover contamination.
	     ══════════════════════════════════════════════════════════════════ -->

	<!-- ── Compact RepeatButton for spinner arrows ─────────────────── -->
	<ControlTheme x:Key="CompactSpinnerRepeatButton" TargetType="RepeatButton">
		<Setter Property="MinWidth" Value="0" />
		<Setter Property="MinHeight" Value="0" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="Foreground" Value="{DynamicResource ComboBoxDropDownGlyphForeground}" />
		<Setter Property="HorizontalContentAlignment" Value="Center" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="Template">
			<ControlTemplate>
				<ContentPresenter x:Name="PART_ContentPresenter"
				                  Background="{TemplateBinding Background}"
				                  Content="{TemplateBinding Content}"
				                  ContentTemplate="{TemplateBinding ContentTemplate}"
				                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
				                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
			</ControlTemplate>
		</Setter>

		<Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundPointerOver}" />
		</Style>
		<Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="#30808080" />
		</Style>
		<Style Selector="^:disabled">
			<Setter Property="Foreground" Value="{DynamicResource ComboBoxDropDownGlyphForegroundDisabled}" />
		</Style>
	</ControlTheme>

	<!-- ── Compact ButtonSpinner — TextBox-like hover ──────────────── -->
	<!--
	     Hover anywhere on the control tints the whole #Background (like
	     TextBox's PART_BorderElement).  The RepeatButtons sit on top with
	     transparent backgrounds, so the tint shows through — matching how
	     TextBox's clear button looks hovered when the text area is hovered.
	     Each button gets an additional tint on its own :pointerover.
	     Suppressed when the TextBox is focused (:focus-within).
	-->
	<ControlTheme x:Key="CompactButtonSpinner" TargetType="ButtonSpinner">
		<Setter Property="Background" Value="{DynamicResource ComboBoxBackground}" />
		<Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderBrush}" />
		<Setter Property="BorderThickness" Value="{DynamicResource ComboBoxBorderThemeThickness}" />
		<Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
		<Setter Property="Foreground" Value="{DynamicResource ComboBoxForeground}" />
		<Setter Property="MinHeight" Value="0" />
		<Setter Property="MinWidth" Value="0" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		<Setter Property="VerticalContentAlignment" Value="Stretch" />
		<Setter Property="Template">
			<ControlTemplate>
				<!-- Panel layers: #Background (visual shell, not hit-testable)
				     sits behind a Grid whose col 0 holds the TextBox and col 1
				     holds the buttons.  Because #Background is not hit-testable,
				     hovering the TextBox fires TextBox:pointerover (which bubbles
				     to ButtonSpinner:pointerover), while hovering a RepeatButton
				     fires only that button's :pointerover — NOT the ButtonSpinner's,
				     because the button is a sibling of #Background in the Panel,
				     not a child of it. -->
				<Panel>
					<Border x:Name="Background"
					        IsHitTestVisible="False"
					        Background="{TemplateBinding Background}"
					        BorderBrush="{TemplateBinding BorderBrush}"
					        BorderThickness="{TemplateBinding BorderThickness}"
					        CornerRadius="{TemplateBinding CornerRadius}" />
					<Grid ColumnDefinitions="*,Auto"
					      Margin="{TemplateBinding BorderThickness}">
						<ContentPresenter Name="PART_ContentPresenter"
						                  Grid.Column="0"
						                  Content="{TemplateBinding Content}"
						                  ContentTemplate="{TemplateBinding ContentTemplate}"
						                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
						                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
						                  Padding="{TemplateBinding Padding}" />
						<StackPanel Grid.Column="1"
						            Orientation="Horizontal"
						            VerticalAlignment="Stretch"
						            IsVisible="{TemplateBinding ShowButtonSpinner}">
							<RepeatButton Name="PART_IncreaseButton"
							              Theme="{StaticResource CompactSpinnerRepeatButton}"
							              Width="16"
							              VerticalAlignment="Stretch"
							              IsTabStop="False">
								<PathIcon Width="12" Height="12"
								          Data="M 1939,1581 L 2029,1491 L 1024,486 L 19,1491 L 109,1581 L 1024,666 Z"
								          Foreground="{DynamicResource ComboBoxDropDownGlyphForeground}" />
							</RepeatButton>
							<RepeatButton Name="PART_DecreaseButton"
							              Theme="{StaticResource CompactSpinnerRepeatButton}"
							              Width="16"
							              Margin="0,0,4,0"
							              VerticalAlignment="Stretch"
							              IsTabStop="False">
								<PathIcon Width="12" Height="12"
								          Data="M 1939,486 L 2029,576 L 1024,1581 L 19,576 L 109,486 L 1024,1401 Z"
								          Foreground="{DynamicResource ComboBoxDropDownGlyphForeground}" />
							</RepeatButton>
						</StackPanel>
					</Grid>
				</Panel>
			</ControlTemplate>
		</Setter>

		<!-- Pointer-over: tint the whole control.  Hovering the text area
		     or a button both fire ButtonSpinner:pointerover (children bubble).
		     This matches TextBox behaviour where PART_BorderElement tints
		     regardless of which child is hovered. -->
		<Style Selector="^:pointerover /template/ Border#Background">
			<Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundPointerOver}" />
			<Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderBrushPointerOver}" />
		</Style>
		<!-- Focused: override hover back to base so the focused TextBox owns
		     all visuals.  This mirrors TextBox where :focus takes precedence
		     over :pointerover. -->
		<Style Selector="^:focus-within /template/ Border#Background">
			<Setter Property="Background" Value="{DynamicResource ComboBoxBackground}" />
			<Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderBrush}" />
		</Style>

		<Style Selector="^:disabled /template/ Border#Background">
			<Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundDisabled}" />
			<Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderBrushDisabled}" />
		</Style>
	</ControlTheme>

	<!-- ── NumericUpDown implicit theme override ───────────────────── -->
	<ControlTheme x:Key="{x:Type NumericUpDown}" TargetType="NumericUpDown">
		<Setter Property="Foreground" Value="{DynamicResource ComboBoxForeground}" />
		<Setter Property="Background" Value="{DynamicResource ComboBoxBackground}" />
		<Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderBrush}" />
		<Setter Property="BorderThickness" Value="{DynamicResource ComboBoxBorderThemeThickness}" />
		<Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
		<Setter Property="MinHeight" Value="0" />
		<Setter Property="Padding" Value="6,6" />
		<Setter Property="FontSize" Value="13" />
		<Setter Property="HorizontalContentAlignment" Value="Left" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="Template">
			<ControlTemplate>
				<DataValidationErrors>
					<ButtonSpinner Name="PART_Spinner"
					               Theme="{StaticResource CompactButtonSpinner}"
					               Background="{TemplateBinding Background}"
					               BorderBrush="{TemplateBinding BorderBrush}"
					               BorderThickness="{TemplateBinding BorderThickness}"
					               CornerRadius="{TemplateBinding CornerRadius}"
					               Padding="0"
					               MinWidth="0"
					               MinHeight="0"
					               HorizontalContentAlignment="Stretch"
					               VerticalContentAlignment="Stretch"
					               AllowSpin="{TemplateBinding AllowSpin}"
					               ShowButtonSpinner="{TemplateBinding ShowButtonSpinner}"
					               ButtonSpinnerLocation="{TemplateBinding ButtonSpinnerLocation}"
					               IsTabStop="False">
						<TextBox Name="PART_TextBox"
						         Background="Transparent"
						         BorderThickness="0"
						         Margin="0"
						         Padding="{TemplateBinding Padding}"
						         MinWidth="0"
						         MinHeight="0"
						         FontSize="{TemplateBinding FontSize}"
						         Foreground="{TemplateBinding Foreground}"
						         Watermark="{TemplateBinding Watermark}"
						         IsReadOnly="{TemplateBinding IsReadOnly}"
						         VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
						         HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
						         AcceptsReturn="False"
						         TextWrapping="NoWrap">
							<TextBox.Resources>
								<!-- Inner TextBox is always transparent — the outer ButtonSpinner
								     shell controls all background visuals including hover. -->
								<SolidColorBrush x:Key="TextControlBackground">Transparent</SolidColorBrush>
								<SolidColorBrush x:Key="TextControlBackgroundPointerOver">Transparent</SolidColorBrush>
								<SolidColorBrush x:Key="TextControlBackgroundFocused">Transparent</SolidColorBrush>
								<SolidColorBrush x:Key="TextControlBorderBrushFocused">Transparent</SolidColorBrush>
								<SolidColorBrush x:Key="TextControlBorderBrushPointerOver">Transparent</SolidColorBrush>
								<Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
							</TextBox.Resources>
						</TextBox>
					</ButtonSpinner>
				</DataValidationErrors>
			</ControlTemplate>
		</Setter>
	</ControlTheme>

</ResourceDictionary>
