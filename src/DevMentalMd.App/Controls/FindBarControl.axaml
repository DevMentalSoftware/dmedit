<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DevMentalMd.App"
             x:Class="DevMentalMd.App.Controls.FindBarControl">

    <!-- No local icon font or hover styles needed — FluentTextBoxButton + global
         ControlButtonIconFont/ControlButtonIconSize handle everything. -->

    <!-- Outer wrapper: 6px taller and 12px wider than the body so the concave
         ear corners have room to render.  Background is transparent so only
         the ear fills and the body itself are visible. -->
    <Grid x:Name="RootGrid" RowDefinitions="6,*" ColumnDefinitions="6,*,6"
          MinWidth="372">

        <!-- Row 0 Col 0: Left concave ear -->
        <Path x:Name="EarLeft" Grid.Row="0" Grid.Column="0"
              Data="M 0,0 L 6,0 L 6,6 A 6,6 0 0 0 0,0 Z" />

        <!-- Row 0 Col 1: Top strip (same bg as body, bridging the ears) -->
        <Border Grid.Row="0" Grid.Column="1" x:Name="TopStrip" />

        <!-- Row 0 Col 2: Right concave ear (mirror of left) -->
        <Path x:Name="EarRight" Grid.Row="0" Grid.Column="2"
              Data="M 6,0 L 0,0 L 0,6 A 6,6 0 0 1 6,0 Z" />

        <!-- Row 1: Main body with rounded bottom corners only -->
        <Border Grid.Row="1" Grid.Column="1"
                x:Name="OuterBorder"
                CornerRadius="0,0,6,6"
                ClipToBounds="True"
                Padding="0,2,6,6">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,8,Auto"
                  RowDefinitions="Auto,Auto,Auto">

                <!-- Col 0: Resize grip (left edge) -->
                <Border x:Name="ResizeGrip"
                        Grid.Column="0" Grid.RowSpan="3"
                        Width="6" Cursor="SizeWestEast"
                        Background="Transparent" />

                <!-- Col 1: Expand/collapse chevron -->
                <Button x:Name="ExpandBtn"
                        Grid.Column="1" Grid.Row="0"
                        VerticalAlignment="Center"
                        Width="24" Height="24" Padding="0"
                        Margin="0,0,4,0"
                        ToolTip.Tip="Toggle Replace">
                    <TextBlock x:Name="ExpandGlyph"
                               Text="&#xF2B1;"
                               FontFamily="{DynamicResource ControlButtonIconFont}"
                               FontSize="{DynamicResource ControlButtonIconSize}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Button>

                <!-- Col 2: SearchBox (star-sized) -->
                <TextBox x:Name="SearchBox"
                         Grid.Column="2" Grid.Row="0"
                         Watermark="Find..."
                         Margin="0,0,4,0">
                    <TextBox.InnerRightContent>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch"
                                    ClipToBounds="True"
                                    Margin="0,1,0,1">
                            <TextBlock x:Name="MatchCount"
                                       Text=""
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0" />
                            <Button x:Name="SearchHistoryBtn"
                                    Theme="{StaticResource FluentTextBoxButton}"
                                    ClipToBounds="True"
                                    ToolTip.Tip="Search history">
                                <TextBlock Text="&#xF2A1;"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Button>
                            <Button x:Name="SearchClearBtn"
                                    Theme="{StaticResource FluentTextBoxButton}"
                                    IsVisible="False"
                                    ClipToBounds="True"
                                    CornerRadius="0,4,4,0"
                                    ToolTip.Tip="Clear search">
                                <TextBlock Text="&#xF369;"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </TextBox.InnerRightContent>
                </TextBox>

                <!-- Col 3: Direction + Menu (Row 0)  /  Replace + Replace All (Row 1) -->
                <StackPanel Grid.Column="3" Grid.Row="0"
                            Orientation="Horizontal" Spacing="2">
                    <Button x:Name="FindDirectionBtn"
                            Height="24" Width="24" Padding="0"
                            ToolTip.Tip="Find in current direction (Enter)">
                        <TextBlock x:Name="DirectionGlyph"
                                   Text="&#xF181;"
                                   FontFamily="{DynamicResource ControlButtonIconFont}"
                                   FontSize="{DynamicResource ControlButtonIconSize}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Button>
                    <Button x:Name="FindMenuBtn"
                            Height="24" Width="24" Padding="0"
                            ToolTip.Tip="Find options">
                        <TextBlock Text="&#xF2A1;"
                                   FontFamily="{DynamicResource ControlButtonIconFont}"
                                   FontSize="{DynamicResource ControlButtonIconSize}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Button>
                </StackPanel>

                <StackPanel x:Name="ReplaceButtons"
                            Grid.Column="3" Grid.Row="1"
                            Orientation="Horizontal" Spacing="2"
                            Margin="0,2,0,0"
                            IsVisible="False">
                    <Button x:Name="ReplaceBtn"
                            Content="Replace" Height="24"
                            ToolTip.Tip="Replace current match" />
                    <Button x:Name="ReplaceAllBtn"
                            Content="Replace All" Height="24"
                            ToolTip.Tip="Replace all matches" />
                </StackPanel>

                <!-- Col 5: Close (Row 0 only) -->
                <Button x:Name="CloseBtn"
                        Grid.Column="5" Grid.Row="0"
                        ToolTip.Tip="Close (Escape)"
                        Width="24" Height="24" Padding="0"
                        VerticalContentAlignment="Center">
                    <TextBlock Text="&#xF369;"
                               FontFamily="{DynamicResource ControlButtonIconFont}"
                               FontSize="{DynamicResource ControlButtonIconSize}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Button>

                <!-- Row 1, Col 2: ReplaceBox (same star column as SearchBox) -->
                <TextBox x:Name="ReplaceBox"
                         Grid.Column="2" Grid.Row="1"
                         Watermark="Replace..."
                         Margin="0,2,4,0"
                         IsVisible="False">
                    <TextBox.InnerRightContent>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch"
                                    ClipToBounds="True"
                                    Margin="0,1,0,1">
                            <Button x:Name="ReplaceHistoryBtn"
                                    Theme="{StaticResource FluentTextBoxButton}"
                                    ClipToBounds="True"
                                    ToolTip.Tip="Replace history">
                                <TextBlock Text="&#xF2A1;"
                                           FontFamily="{DynamicResource ControlButtonIconFont}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Button>
                            <Button x:Name="ReplaceClearBtn"
                                    Theme="{StaticResource FluentTextBoxButton}"
                                    IsVisible="False"
                                    ClipToBounds="True"
                                    CornerRadius="0,4,4,0"
                                    ToolTip.Tip="Clear replace">
                                <TextBlock Text="&#xF369;"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </TextBox.InnerRightContent>
                </TextBox>

                <!-- Row 2: Options (spans Col 2–5) -->
                <DockPanel Grid.Column="2" Grid.ColumnSpan="4" Grid.Row="2"
                           Margin="0,4,0,0">
                    <ToggleButton x:Name="MatchCaseBtn"
                                  DockPanel.Dock="Left"
                                  Content="Abc" Height="24"
                                  ToolTip.Tip="Match Case" />
                    <ToggleButton x:Name="WholeWordBtn"
                                  DockPanel.Dock="Left"
                                  Content="w" Height="24"
                                  Width="24"
                                  Margin="4,0,0,0"
                                  ToolTip.Tip="Match Whole Word" />
                    <Border DockPanel.Dock="Left"
                            Width="1" Margin="8,2"
                            x:Name="OptionsSeparator" />
                    <ComboBox x:Name="SearchModeBox"
                              DockPanel.Dock="Left"
                              SelectedIndex="0"
                              MinWidth="100"
                              ToolTip.Tip="Search mode">
                        <ComboBoxItem Content="Normal" />
                        <ComboBoxItem Content="Wildcard" />
                        <ComboBoxItem Content="Regex" />
                    </ComboBox>
                    <Border DockPanel.Dock="Left"
                            Width="1" Margin="8,2"
                            x:Name="OptionsSeparator2" />
                    <ComboBox x:Name="ScopeBox"
                              SelectedIndex="0"
                              HorizontalAlignment="Stretch"
                              ToolTip.Tip="Search scope">
                        <ComboBoxItem Content="Current document" />
                        <ComboBoxItem Content="Open documents" />
                    </ComboBox>
                </DockPanel>

            </Grid>
        </Border>

        <!-- Search history popup -->
        <Popup x:Name="SearchHistoryPopup"
               PlacementTarget="{Binding #SearchBox}"
               Placement="Bottom"
               IsLightDismissEnabled="True"
               MaxHeight="200">
            <Border Background="{DynamicResource MenuFlyoutPresenterBackground}"
                    BorderBrush="{DynamicResource MenuFlyoutPresenterBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="0">
                <ListBox x:Name="SearchHistoryList"
                         MaxHeight="190"
                         MinWidth="200" />
            </Border>
        </Popup>

        <!-- Replace history popup -->
        <Popup x:Name="ReplaceHistoryPopup"
               PlacementTarget="{Binding #ReplaceBox}"
               Placement="Bottom"
               IsLightDismissEnabled="True"
               MaxHeight="200">
            <Border Background="{DynamicResource MenuFlyoutPresenterBackground}"
                    BorderBrush="{DynamicResource MenuFlyoutPresenterBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="0">
                <ListBox x:Name="ReplaceHistoryList"
                         MaxHeight="190"
                         MinWidth="200" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
