<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DevMentalMd.App.Controls.ControlGalleryWindow"
        Title="Control Gallery"
        Width="450" Height="550"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer Padding="16">
        <StackPanel Spacing="20">

            <!-- ── TextBox ──────────────────────────────────── -->
            <StackPanel Spacing="6">
                <TextBlock Text="TextBox" FontWeight="Bold" FontSize="14" />
                <TextBox Watermark="Watermark text (empty)" />
                <TextBox Text="With text content" />
                <TextBox Text="Disabled" IsEnabled="False" />
            </StackPanel>

            <!-- ── Button ───────────────────────────────────── -->
            <StackPanel Spacing="6">
                <TextBlock Text="Button" FontWeight="Bold" FontSize="14" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Normal" />
                    <Button Content="Disabled" IsEnabled="False" />
                </StackPanel>
            </StackPanel>

            <!-- ── ToggleButton ─────────────────────────────── -->
            <StackPanel Spacing="6">
                <TextBlock Text="ToggleButton" FontWeight="Bold" FontSize="14" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ToggleButton Content="Unchecked" />
                    <ToggleButton Content="Checked" IsChecked="True" />
                    <ToggleButton Content="Disabled" IsEnabled="False" />
                </StackPanel>
            </StackPanel>

            <!-- ── ComboBox ─────────────────────────────────── -->
            <StackPanel Spacing="6">
                <TextBlock Text="ComboBox" FontWeight="Bold" FontSize="14" />
                <ComboBox SelectedIndex="1" HorizontalAlignment="Left" MinWidth="200">
                    <ComboBoxItem Content="First item" />
                    <ComboBoxItem Content="Selected item" />
                    <ComboBoxItem Content="Third item" />
                </ComboBox>
            </StackPanel>

            <!-- ── NumericUpDown ───────────────────────────────── -->
            <StackPanel Spacing="6">
                <TextBlock Text="NumericUpDown" FontWeight="Bold" FontSize="14" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <NumericUpDown Value="42" Minimum="0" Maximum="100" Width="120" />
                    <NumericUpDown Value="0" IsEnabled="False" Width="120" />
                </StackPanel>
            </StackPanel>

            <!-- ── ListBox ──────────────────────────────────── -->
            <StackPanel Spacing="6">
                <TextBlock Text="ListBox" FontWeight="Bold" FontSize="14" />
                <ListBox SelectedIndex="1" MaxHeight="120">
                    <ListBoxItem Content="First item" />
                    <ListBoxItem Content="Selected item" />
                    <ListBoxItem Content="Third item" />
                </ListBox>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>