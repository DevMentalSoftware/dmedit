<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DevMentalMd.App.App"
             RequestedThemeVariant="Default">
	<!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

	<Application.Styles>
		<FluentTheme />
		<Style Selector="TextBox">
			<Setter Property="Padding" Value="4,4" />
			<Setter Property="MinHeight" Value="0" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
		<Style Selector="Button">
			<Setter Property="Padding" Value="4,4" />
			<Setter Property="MinHeight" Value="0" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
	</Application.Styles>
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<ResourceDictionary x:Key="Light">
					<SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#AA000000" />
					<SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#AA000000" />
				</ResourceDictionary>
				<ResourceDictionary x:Key="Dark">
					<SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#FFFFFFFF" />
					<SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#FFFFFFFF" />
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>
		</ResourceDictionary>
	</Application.Resources>
</Application>