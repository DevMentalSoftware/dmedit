<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DevMentalMd.App.Settings.SettingsControl">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="200" MaxWidth="400" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <!-- Left column: search + categories -->
        <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top" Padding="8" BorderThickness="0,0,1,1"
                    x:Name="SearchBarBorder">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="SearchBox" Grid.Column="0" Grid.ColumnSpan="2"
                             Watermark="Search settings..."
                             FontSize="13" />
                    <Button x:Name="SearchClearBtn" Grid.Column="1"
                            Content="✕" FontSize="12"
                            Padding="10,0" Margin="0,1,0,1"
                            Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Stretch"
                            IsVisible="False" />
                </Grid>
            </Border>
            <Border BorderThickness="0,0,1,0" x:Name="SidebarBorder">
                <ListBox x:Name="CategoryList"
                         Padding="4"
                         FontSize="13"
                         SelectionMode="Single" />
            </Border>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="3"/>

        <!-- Settings content -->
        <ScrollViewer x:Name="ContentScroll" Grid.Column="2"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      AllowAutoHide="False">
            <ScrollViewer.Styles>
                <Style Selector="ScrollBar:vertical">
                    <Setter Property="Margin" Value="0,0,0,8" />
                </Style>
            </ScrollViewer.Styles>
            <StackPanel x:Name="SettingsContent"
                        Spacing="0"
                        Margin="0,0,0,20" />
        </ScrollViewer>
    </Grid>
</UserControl>
