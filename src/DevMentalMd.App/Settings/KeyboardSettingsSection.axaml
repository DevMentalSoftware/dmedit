<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DevMentalMd.App.Settings.KeyboardSettingsSection">
	<!-- StackPanel stacks items at their natural height — no fill element and
	     no dead space.  MaxHeight on CommandScroll (set from code) caps the
	     inner scroll area so the full list scrolls internally. -->
	<UserControl.Styles>
		<!-- Clear buttons sit inside TextBox grids; use an opaque hover so the
		     focused TextBox background doesn't bleed through the default
		     semi-transparent ButtonBackgroundPointerOver (#20808080). -->
		<Style Selector="Button.textBoxClear:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource TextControlButtonBackgroundPointerOver}" />
		</Style>
	</UserControl.Styles>
	<StackPanel Margin="12,8,12,8">

		<!-- Profile selector -->
		<ComboBox x:Name="ProfileCombo"
		          Margin="0,0,0,6"
		          MinWidth="130" />

		<!-- Filter row: fixed column widths (230 name, 160 shortcut filter, * remainder)
		     tuned to visually align with the command list columns below. -->
		<Border Width="580"
		        HorizontalAlignment="Left">
			<Grid ColumnDefinitions="226,160,*" ColumnSpacing="8">
				<Grid Grid.Column="0" ColumnDefinitions="*,Auto" >
					<TextBox x:Name="NameFilter"
					         Grid.ColumnSpan="2"
					         Watermark="Search commands&#x2026;"
					         MinWidth="160" />
					<Button x:Name="NameFilterClearBtn"
					        Grid.Column="1"
					        Classes="textBoxClear"
					        Content="&#x2715;"
					        FontSize="11"
					        Padding="12,0"
					        Background="Transparent"
					        BorderThickness="0"
					        CornerRadius="0,4,4,0"
					        VerticalAlignment="Stretch"
					        HorizontalAlignment="Right"
					        Margin="0,1,0,1"
					        IsVisible="False"
					        Cursor="Arrow" />
				</Grid>
				<Grid ColumnDefinitions="*,Auto" Grid.Column="1">
					<TextBox x:Name="FindShortcut"
							 Grid.ColumnSpan="2"
							 Watermark="Find Shortcut&#x2026;"
							 IsReadOnly="True"
							 />
					<Button x:Name="FindClearBtn"
							Grid.Column="1"
							Classes="textBoxClear"
							Content="&#x2715;"
							FontSize="11"
							Padding="12,0"
							Background="Transparent"
							BorderThickness="0"
							CornerRadius="0,4,4,0"
							VerticalAlignment="Stretch"
							HorizontalAlignment="Right"
							Margin="0,1,0,1"
							IsVisible="False"
							Cursor="Arrow" />
				</Grid>
				<ToggleButton x:Name="ModifiedFilterBtn"
				              Grid.Column="2"
				              Content="M"
				              FontSize="16"
				              FontWeight="SemiBold"
				              Padding="7,3"
				              Margin="0,0,0,0"
				              HorizontalAlignment="Left"
				              VerticalAlignment="Stretch"
				              ToolTip.Tip="Show modified only" />
			</Grid>
		</Border>

		<!-- Scroll hint (shown when outer page needs scrolling) -->
		<TextBlock x:Name="ScrollHint"
		           Text="Ctrl+Scroll to scroll this list when the page also scrolls."
		           FontSize="11"
		           Margin="0,2,0,0"
		           IsVisible="False" />

		<!-- Scrollable command list inside a subtle border.
		     MaxHeight is set from SetAvailableHeight() to cap the inner scroll
		     area; the StackPanel parent sizes this to content when filtered. -->
		<Border x:Name="CommandListBorder"
		        BorderThickness="1"
		        CornerRadius="3"
		        Margin="0,6,0,6"
		        Width="600"
		        HorizontalAlignment="Left">
			<ScrollViewer x:Name="CommandScroll"
			              HorizontalScrollBarVisibility="Disabled"
			              VerticalScrollBarVisibility="Auto"
			              AllowAutoHide="False">
				<!-- Add symmetric top margin so the up-arrow button has the same
				     spacing from the border as the down-arrow button, which inherits
				     a bottom margin from the outer ContentScroll style. -->
				<ScrollViewer.Styles>
					<Style Selector="ScrollBar:vertical">
						<Setter Property="Margin" Value="0,8,0,8" />
					</Style>
				</ScrollViewer.Styles>
				<StackPanel x:Name="CommandList" Spacing="0" />
			</ScrollViewer>
		</Border>

		<!-- Action buttons -->
		<WrapPanel Orientation="Horizontal">
			<Grid MaxWidth="260" ColumnDefinitions="*,Auto">
				<TextBox x:Name="CaptureBox"
				         Grid.ColumnSpan="2"
				         Watermark="Press shortcut keys&#x2026;"
				         FontSize="13"
				         IsReadOnly="True"
				         MinWidth="180" />
				<Button x:Name="CaptureClearBtn"
				        Grid.Column="1"
				        Classes="textBoxClear"
				        Content="&#x2715;"
				        FontSize="11"
				        Padding="12,0"
				        Background="Transparent"
				        BorderThickness="0"
				        CornerRadius="0,4,4,0"
				        VerticalAlignment="Stretch"
				        HorizontalAlignment="Right"
				        Margin="0,1,0,1"
				        IsVisible="False"
				        Cursor="Arrow" />
			</Grid>
			<Button x:Name="AssignBtn" Content="Assign" Margin="8,0,4,0" />
			<Button x:Name="RemoveBtn" Content="Remove" Margin="0,0,4,0" />
			<Button x:Name="ResetBtn" Content="Reset" />
		</WrapPanel>

		<!-- Replacement notice: "Will replace the shortcut already assigned to [Cmd]".
		     Empty (no height) when no conflict. Built from code. -->
		<StackPanel x:Name="ConflictPanel"
		            Orientation="Horizontal"
		            Margin="0,4,0,0" />

	</StackPanel>
</UserControl>
